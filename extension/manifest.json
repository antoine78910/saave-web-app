{
  "manifest_version": 3,
  "name": "Saave - Bookmark Manager",
  "version": "1.0",
  "description": "Quickly save bookmarks to your Saave collection",
  
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "notifications"
  ],
  
  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "http://localhost:3002/*",
    "http://localhost:3003/*",
    "http://localhost:3004/*",
    "http://localhost:3005/*",
    "http://localhost:3006/*",
    "http://localhost:3007/*",
    "http://localhost:3008/*",
    "http://localhost:3009/*",
    "http://localhost:3010/*",
    "https://*/*",
    "http://*/*"
  ],
  
  "action": {
    "default_title": "Add to Saave"
  },
  
  "background": {
    "service_worker": "background.js"
  },
  
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}